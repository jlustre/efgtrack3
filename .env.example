APP_NAME=EFGTrack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Vancouver
APP_URL=http://efgtrack.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=efgtrack
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@efgtrack.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
TINYMCE_API_KEY=
VITE_TINYMCE_API_KEY=

# Notification delivery (enabled by default in local with log driver)
NOTIFICATIONS_SMS_ENABLED=true
NOTIFICATIONS_SMS_DRIVER=log
NOTIFICATIONS_SMS_FROM=EFGTrack
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

NOTIFICATIONS_PUSH_ENABLED=true
NOTIFICATIONS_PUSH_DRIVER=log
NOTIFICATIONS_PUSH_VAPID_SUBJECT="${APP_URL}"
NOTIFICATIONS_PUSH_VAPID_PUBLIC_KEY=
NOTIFICATIONS_PUSH_VAPID_PRIVATE_KEY=

# CFM portal SMS reuses notification SMS transport when enabled
CFM_SMS_ENABLED=true
CFM_SMS_DRIVER=log
